{
    "info": {
        "name": "DeliveryNotes",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Crear albarán (material)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "const response = pm.response.json();",
                            "",
                            "if (response.data && response.data._id) {",
                            "    pm.environment.set(\"deliveryNoteId\", response.data._id);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{accessToken}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "POST",
                "header": [],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"project\": \"{{projectId}}\",\n  \"client\": \"{{clientId}}\",\n  \"format\": \"material\",\n  \"workDate\": \"2025-01-15\",\n  \"description\": \"Entrega de materiales para reforma\",\n  \"material\": \"Cemento gris 25kg\",\n  \"quantity\": 20,\n  \"unit\": \"sacos\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "http://localhost:3000/api/deliverynote",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "3000",
                    "path": ["api", "deliverynote"]
                }
            }
        },
