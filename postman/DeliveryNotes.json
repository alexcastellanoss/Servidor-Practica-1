        {
            "name": "Listar albaranes",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Response has pagination\", function () {",
                            "    const response = pm.response.json();",
                            "    pm.expect(response).to.have.property('pagination');",
                            "    pm.expect(response.pagination).to.have.property('totalPages');",
                            "    pm.expect(response.pagination).to.have.property('totalItems');",
                            "    pm.expect(response.pagination).to.have.property('currentPage');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{accessToken}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:3000/api/deliverynote?page=1&limit=10",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "3000",
                    "path": ["api", "deliverynote"],
                    "query": [
                        {
                            "key": "page",
                            "value": "1"
                        },
                        {
                            "key": "limit",
                            "value": "10"
                        },
                        {
                            "key": "project",
                            "value": "{{projectId}}",
                            "disabled": true
                        },
                        {
                            "key": "client",
                            "value": "{{clientId}}",
                            "disabled": true
                        },
                        {
                            "key": "format",
                            "value": "material",
                            "disabled": true
                        },
                        {
                            "key": "signed",
                            "value": "true",
                            "disabled": true
                        },
                        {
                            "key": "from",
                            "value": "2025-01-01",
                            "disabled": true
                        },
                        {
                            "key": "to",
                            "value": "2025-12-31",
                            "disabled": true
                        }
                    ]
                }
            }
        },
