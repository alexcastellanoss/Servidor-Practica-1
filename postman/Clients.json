{
    "info": {
        "name": "Clients",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Crear cliente",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "const response = pm.response.json();",
                            "",
                            "if (response.data && response.data._id) {",
                            "    pm.environment.set(\"clientId\", response.data._id);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{accessToken}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "POST",
                "header": [],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"García Construcciones SL\",\n  \"cif\": \"B12345678\",\n  \"email\": \"contacto@garciaconstrucciones.com\",\n  \"phone\": \"912345678\",\n  \"address\": {\n    \"street\": \"Calle Mayor\",\n    \"number\": \"45\",\n    \"postal\": \"28013\",\n    \"city\": \"Madrid\",\n    \"province\": \"Madrid\"\n  }\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "http://localhost:3000/api/client",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "3000",
                    "path": ["api", "client"]
                }
            }
        },
        {
            "name": "Listar clientes",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Response has pagination\", function () {",
                            "    const response = pm.response.json();",
                            "    pm.expect(response).to.have.property('pagination');",
                            "    pm.expect(response.pagination).to.have.property('totalPages');",
                            "    pm.expect(response.pagination).to.have.property('totalItems');",
                            "    pm.expect(response.pagination).to.have.property('currentPage');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{accessToken}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:3000/api/client?page=1&limit=10",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "3000",
                    "path": ["api", "client"],
                    "query": [
                        {
                            "key": "page",
                            "value": "1"
                        },
                        {
                            "key": "limit",
                            "value": "10"
                        },
                        {
                            "key": "name",
                            "value": "García",
                            "disabled": true
                        }
                    ]
                }
            }
        },
