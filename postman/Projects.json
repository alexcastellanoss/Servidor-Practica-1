{
    "info": {
        "name": "Projects",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Crear proyecto",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "const response = pm.response.json();",
                            "",
                            "if (response.data && response.data._id) {",
                            "    pm.environment.set(\"projectId\", response.data._id);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{accessToken}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "POST",
                "header": [],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"client\": \"{{clientId}}\",\n  \"name\": \"Reforma integral vivienda\",\n  \"projectCode\": \"REFORMA-2025-001\",\n  \"address\": {\n    \"street\": \"Calle Mayor\",\n    \"number\": \"45\",\n    \"postal\": \"28013\",\n    \"city\": \"Madrid\",\n    \"province\": \"Madrid\"\n  },\n  \"email\": \"proyecto@garciaconstrucciones.com\",\n  \"notes\": \"Proyecto de reforma completa\",\n  \"active\": true\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "http://localhost:3000/api/project",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "3000",
                    "path": ["api", "project"]
                }
            }
        },
        {
            "name": "Listar proyectos",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Response has pagination\", function () {",
                            "    const response = pm.response.json();",
                            "    pm.expect(response).to.have.property('pagination');",
                            "    pm.expect(response.pagination).to.have.property('totalPages');",
                            "    pm.expect(response.pagination).to.have.property('totalItems');",
                            "    pm.expect(response.pagination).to.have.property('currentPage');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{accessToken}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:3000/api/project?page=1&limit=10",
                    "protocol": "http",
                    "host": ["localhost"],
                    "port": "3000",
                    "path": ["api", "project"],
                    "query": [
                        {
                            "key": "page",
                            "value": "1"
                        },
                        {
                            "key": "limit",
                            "value": "10"
                        },
                        {
                            "key": "client",
                            "value": "{{clientId}}",
                            "disabled": true
                        },
                        {
                            "key": "name",
                            "value": "Reforma",
                            "disabled": true
                        },
                        {
                            "key": "active",
                            "value": "true",
                            "disabled": true
                        }
                    ]
                }
            }
        },
